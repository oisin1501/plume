{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:webview:allow-webview-position",
    "core:webview:allow-set-webview-position",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
